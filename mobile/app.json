{
  "expo": {
    "name": "Pick'em Poker",
    "slug": "pickem-poker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "pickem-poker",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a1611"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pickempoker.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1611"
      },
      "package": "com.pickempoker.app"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      },
      "supabaseUrl": "",
      "supabaseAnonKey": ""
    }
  }
}
